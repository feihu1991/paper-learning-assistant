{
  "task_id": "devops_001",
  "type": "devops",
  "objective": "部署用户管理服务到生产环境",
  "description": "将用户管理服务部署到 Kubernetes 生产环境，使用蓝绿部署策略确保零停机",
  "specs": {
    "application": "user-management-service",
    "version": "v1.2.3",
    "environment": "production",
    "deployment_strategy": "blue-green",
    "infrastructure": {
      "platform": "kubernetes",
      "cloud_provider": "aws",
      "region": "us-east-1",
      "cluster": "production-cluster",
      "namespace": "production"
    },
    "resources": {
      "cpu": {
        "request": "500m",
        "limit": "1000m"
      },
      "memory": {
        "request": "1Gi",
        "limit": "2Gi"
      },
      "storage": {
        "size": "20Gi",
        "type": "gp3"
      }
    },
    "scaling": {
      "min_replicas": 3,
      "max_replicas": 10,
      "metrics": [
        {
          "type": "cpu",
          "target": "70%"
        },
        {
          "type": "memory",
          "target": "80%"
        },
        {
          "type": "custom",
          "name": "request_rate",
          "target": "1000"
        }
      ]
    },
    "monitoring": {
      "metrics": ["cpu_usage", "memory_usage", "response_time", "error_rate", "request_rate"],
      "alerts": [
        {
          "name": "HighErrorRate",
          "condition": "error_rate > 5% for 2 minutes",
          "severity": "critical"
        },
        {
          "name": "HighLatency",
          "condition": "p95_response_time > 1s for 5 minutes",
          "severity": "warning"
        },
        {
          "name": "ServiceDown",
          "condition": "up == 0 for 1 minute",
          "severity": "critical"
        }
      ],
      "dashboard": true
    },
    "security": {
      "image_scanning": true,
      "vulnerability_check": true,
      "secret_management": true,
      "compliance_check": true,
      "network_policy": true
    }
  },
  "shared_context": [
    "/dev-team/shared/docs/devops_agent_config.md",
    "/dev-team/shared/docs/deployment_guidelines.md",
    "/dev-team/shared/docs/tech_stack.md",
    "/dev-team/shared/output/be/user-management/",
    "/dev-team/shared/output/qa/qa_001/"
  ],
  "priority": "high",
  "deadline": "2024-03-10T20:00:00+08:00",
  "dependencies": ["be_001", "qa_001"],
  "prerequisites": [
    "单元测试通过率 ≥ 95%",
    "集成测试通过率 ≥ 90%",
    "代码覆盖率 ≥ 80%",
    "安全扫描无严重漏洞",
    "性能测试符合要求"
  ],
  "rollback_plan": {
    "automatic": true,
    "conditions": ["error_rate > 10%", "response_time > 3s", "health_check_failed > 3 times"],
    "steps": [
      "自动切换到蓝色环境",
      "发送回滚通知",
      "记录回滚原因",
      "安排问题排查会议"
    ],
    "timeout": "5分钟"
  },
  "communication_plan": {
    "pre_deployment": [
      "提前24小时发送部署通知",
      "召开部署计划会议",
      "最终确认检查清单"
    ],
    "during_deployment": [
      "每5分钟发送状态更新",
      "实时问题通报",
      "关键决策点确认"
    ],
    "post_deployment": [
      "部署完成通知",
      "性能指标报告",
      "安排部署回顾会议"
    ],
    "channels": ["slack#deployments", "email", "teams"]
  },
  "deployment_steps": [
    {
      "name": "环境准备",
      "description": "准备部署环境",
      "actions": [
        "创建命名空间",
        "配置网络策略",
        "设置资源配额"
      ]
    },
    {
      "name": "镜像构建和推送",
      "description": "构建Docker镜像并推送到仓库",
      "actions": [
        "构建应用镜像",
        "安全扫描镜像",
        "推送到镜像仓库"
      ]
    },
    {
      "name": "配置部署",
      "description": "配置Kubernetes部署资源",
      "actions": [
        "创建ConfigMap",
        "创建Secret",
        "创建Deployment",
        "创建Service",
        "创建Ingress"
      ]
    },
    {
      "name": "蓝绿部署",
      "description": "执行蓝绿部署",
      "actions": [
        "部署绿色环境",
        "验证绿色环境",
        "切换流量到绿色",
        "清理蓝色环境"
      ]
    },
    {
      "name": "监控配置",
      "description": "配置监控和告警",
      "actions": [
        "配置Prometheus监控",
        "创建Grafana仪表板",
        "设置告警规则"
      ]
    },
    {
      "name": "验证测试",
      "description": "验证部署结果",
      "actions": [
        "健康检查",
        "性能测试",
        "功能验证",
        "安全验证"
      ]
    }
  ],
  "output_requirements": {
    "artifacts": [
      "kubernetes部署配置",
      "监控配置",
      "告警规则",
      "部署脚本",
      "回滚脚本"
    ],
    "reports": [
      "部署报告",
      "性能测试报告",
      "安全扫描报告",
      "监控报告"
    ],
    "delivery_path": "/dev-team/shared/output/devops/devops_001/"
  },
  "acceptance_criteria": [
    "部署在30分钟内完成",
    "所有Pod处于Running状态",
    "健康检查全部通过",
    "API响应时间 < 200ms",
    "错误率 < 0.1%",
    "监控仪表板可访问",
    "告警规则生效",
    "文档更新完成"
  ],
  "success_metrics": {
    "deployment_time": "≤ 30分钟",
    "success_rate": "100%",
    "rollback_rate": "0%",
    "incident_count": "0",
    "downtime": "0秒"
  },
  "risk_assessment": {
    "high_risk": [
      "数据库迁移",
      "重大架构变更",
      "第三方服务集成变更"
    ],
    "mitigation": [
      "提前进行数据备份",
      "准备回滚计划",
      "分阶段部署",
      "密切监控关键指标"
    ]
  },
  "post_deployment_tasks": [
    {
      "task": "性能监控",
      "duration": "24小时",
      "metrics": ["response_time", "error_rate", "resource_usage"]
    },
    {
      "task": "用户反馈收集",
      "duration": "48小时",
      "channels": ["用户支持", "错误报告", "性能反馈"]
    },
    {
      "task": "部署回顾",
      "timing": "部署后3天内",
      "topics": ["成功经验", "遇到的问题", "改进建议"]
    }
  ]
}