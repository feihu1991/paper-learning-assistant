  "service_design": [
    {
      "service_name": "user-service",
      "responsibility": "用户管理、认证授权",
      "technology": "Node.js + TypeScript + PostgreSQL",
      "scale": "3 replicas, 自动扩缩容",
      "apis": ["/api/users/*", "/api/auth/*"]
    },
    {
      "service_name": "product-service",
      "responsibility": "商品管理、分类搜索",
      "technology": "Node.js + MongoDB + Elasticsearch",
      "scale": "5 replicas, 读写分离",
      "apis": ["/api/products/*", "/api/categories/*"]
    },
    {
      "service_name": "order-service",
      "responsibility": "订单管理、支付处理",
      "technology": "Java + Spring Boot + PostgreSQL",
      "scale": "10 replicas, 高可用",
      "apis": ["/api/orders/*", "/api/payments/*"]
    },
    {
      "service_name": "inventory-service",
      "responsibility": "库存管理、物流跟踪",
      "technology": "Go + PostgreSQL + Redis",
      "scale": "5 replicas, 强一致性",
      "apis": ["/api/inventory/*", "/api/shipping/*"]
    },
    {
      "service_name": "notification-service",
      "responsibility": "消息通知、推送",
      "technology": "Python + Redis + Kafka",
      "scale": "3 replicas, 异步处理",
      "apis": ["/api/notifications/*"]
    }
  ],
  "infrastructure_design": {
    "kubernetes_cluster": {
      "nodes": "3 master + 5 worker nodes",
      "ingress": "Nginx Ingress Controller",
      "service_mesh": "Istio (可选)",
      "monitoring": "Prometheus + Grafana"
    },
    "database_cluster": {
      "postgresql": "主从复制，读写分离",
      "mongodb": "分片集群",
      "redis": "哨兵模式集群",
      "backup": "每日全量 + 实时增量备份"
    },
    "message_queue": {
      "kafka": "3节点集群",
      "topics": ["orders", "payments", "notifications"],
      "retention": "7天"
    }
  },
